{
  "name": "s4yt-api",
  "version": "2.3.5",
  "author": "Jonathan Lam",
  "contributors": [
    "David Bishop",
    "Krzysztof Garbos",
    "Jonathan Lam",
    "Soham Desai",
    "Shema Dabiri",
    "Siddhanth Subramanian",
    "Akpevwen Sebastian Gbudje"
  ],
  "description": "This is the special event/'game', called Dollars for Your Thoughts ($4YT), back-end REST API for Building-u.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/buildingu/s4yt-api.git"
  },
  "main": "src/v2/server.ts",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development nodemon",
    "test": "echo \"Error: no test specified\" && exit 1",
    "check-ts": "npx tsc --noEmit",
    "seedDB": "node --loader ts-node/esm --experimental-specifier-resolution=node ./src/v2/seeders/test/seeder.ts",
    "addData": "node --loader ts-node/esm --experimental-specifier-resolution=node ./src/v2/seeders/prod/addData.ts",
    "createChests": "node --loader ts-node/esm --experimental-specifier-resolution=node ./src/v2/seeders/createChests.ts",
    "copyWinners": "node --loader ts-node/esm --experimental-specifier-resolution=node ./src/v2/seeders/copyWinners.ts",
    "generateTestCodes": "node --loader ts-node/esm --experimental-specifier-resolution=node ./src/v2/seeders/utils.ts",
    "build": "webpack --config webpack.config.cjs",
    "serve": "cross-env NODE_ENV=production node ./build/server.cjs",
    "clean": "rm -rf node_modules"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cookie-parser": "1.4.7",
    "cors": "2.8.6",
    "cross-env": "10.1.0",
    "dotenv": "17.4.2",
    "express": "^4.22.2",
    "helmet": "8.2.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "9.0.3",
    "mongoose": "9.6.2",
    "morgan": "1.10.1",
    "node-schedule": "2.1.1",
    "resend": "6.12.3",
    "socket.io": "4.8.3",
    "uuidv4": "6.2.13",
    "winston": "3.19.0",
    "winston-daily-rotate-file": "5.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/body-parser": "1.19.6",
    "@types/cookie-parser": "1.4.10",
    "@types/cors": "2.8.19",
    "@types/express": "^4.17.25",
    "@types/hpp": "^0.2.7",
    "@types/jsonwebtoken": "9.0.10",
    "@types/morgan": "1.9.10",
    "@types/node": "25.9.1",
    "@types/node-schedule": "2.1.8",
    "@types/nodemailer": "8.0.0",
    "copy-webpack-plugin": "14.0.0",
    "esm": "3.2.25",
    "nodemon": "^3.1.14",
    "path": "0.12.7",
    "ts-loader": "9.5.7",
    "ts-node": "10.9.2",
    "typescript": "6.0.3",
    "webpack": "^5.107.1",
    "webpack-cli": "7.0.2",
    "webpack-node-externals": "3.0.0"
  }
}
