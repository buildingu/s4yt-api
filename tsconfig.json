{
  "compilerOptions": {
    "target": "ES2020", 
    "lib": ["ES2020"],
    "module": "ESNext", 
    "moduleResolution": "Node", 
    "sourceMap": true,
    "allowJs": true,
    "esModuleInterop": true,
    "resolveJsonModule": true, 
    "isolatedModules": true, 
    "strict": true,
    "ignoreDeprecations": "6.0"
  },
  "exclude": [
    "node_modules", 
    "build/**/*", 
    "**/*.js", 
    "**/*.cjs" 
  ],
  "include": ["src/**/*"] 
}
